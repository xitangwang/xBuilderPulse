# --- VAPID keys for Web Push (required) ---
# Generate with: node scripts/generate-vapid.mjs
# PUBLIC_ prefix is exposed to the browser; the private key must stay server-side.
PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# mailto: address shown to push services (required)
VAPID_SUBJECT=mailto:you@example.com

# --- Upstash Redis (required for storing push subscriptions) ---
# Auto-injected when you connect a Vercel Marketplace Upstash DB.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Vercel Deploy Hook + Cron secret (required for daily auto-update) ---
# Deploy Hook URL from Vercel project settings.
DEPLOY_HOOK_URL=
# Random string. Vercel Cron sends it in Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# --- Optional: higher GitHub rate limit during build ---
GITHUB_TOKEN=
