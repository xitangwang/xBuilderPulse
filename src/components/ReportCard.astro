---
import type { ReportMeta } from '../lib/github';

interface Props {
  meta: ReportMeta;
  summary?: string;
  featured?: boolean;
}

const { meta, summary, featured = false } = Astro.props;
const href = `/${meta.lang}/${meta.year}/${meta.slug}`;

const d = new Date(meta.date + 'T00:00:00Z');
const formatted = meta.lang === 'zh'
  ? `${d.getUTCFullYear()} 年 ${d.getUTCMonth() + 1} 月 ${d.getUTCDate()} 日`
  : d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });

// Strip markdown for preview
const preview = summary
  ? summary
      .replace(/\*\*([^*]+)\*\*/g, '$1')
      .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
      .replace(/`([^`]+)`/g, '$1')
      .replace(/\n+/g, ' ')
      .slice(0, featured ? 280 : 160)
  : '';
---

<a
  href={href}
  class="block rounded-xl border p-4 transition-colors active:scale-[0.99]"
  style="background: var(--color-card); border-color: var(--color-border);"
>
  <div class="flex items-center gap-2 text-xs" style="color: var(--color-muted);">
    <time datetime={meta.date}>{formatted}</time>
    {featured && (
      <span
        class="px-2 py-0.5 rounded-full text-[10px] font-semibold uppercase tracking-wide"
        style="background: var(--color-accent); color: white;"
      >{meta.lang === 'zh' ? '最新' : 'Latest'}</span>
    )}
  </div>
  {preview && (
    <p class={`mt-2 ${featured ? 'text-base' : 'text-sm'} leading-relaxed`}
       style="color: var(--color-fg);">
      {preview}{preview.length >= (featured ? 280 : 160) ? '…' : ''}
    </p>
  )}
  <div class="mt-3 flex items-center justify-between">
    <span class="text-xs" style="color: var(--color-muted);">
      {meta.lang === 'zh' ? '阅读全文' : 'Read'}
    </span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" style="color: var(--color-muted);">
      <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </div>
</a>
