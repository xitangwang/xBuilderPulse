---
interface Props {
  lang?: 'en' | 'zh';
}

const { lang = 'en' } = Astro.props;
const upstream = 'https://github.com/BuilderPulse/BuilderPulse';
---

<footer
  class="mt-12 border-t"
  style="border-color: var(--color-border);"
>
  <div
    class="mx-auto max-w-2xl px-4 py-6 text-xs text-center space-y-2"
    style="color: var(--color-muted);"
  >
    <p>
      <a
        href={`/${lang}/rss.xml`}
        class="inline-flex items-center gap-1 underline underline-offset-2 hover:text-[color:var(--color-accent)]"
      >
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.18 15.64a2.18 2.18 0 1 1 0 4.36 2.18 2.18 0 0 1 0-4.36zM4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44zm0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z" />
        </svg>
        RSS
      </a>
    </p>
    <p>
      Powered by{' '}
      <a
        href={upstream}
        rel="noopener noreferrer"
        target="_blank"
        class="underline underline-offset-2 hover:text-[color:var(--color-accent)]"
        style="color: var(--color-fg);"
      >
        BuilderPulse/BuilderPulse
      </a>
    </p>
    <p>
      {
        lang === 'zh'
          ? '本站为第三方阅读器，与原作者无关。'
          : 'Unofficial reader. Not affiliated with BuilderPulse.'
      }
    </p>
  </div>
</footer>
