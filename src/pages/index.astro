---
// Root entry redirects to the language auto-detected in the browser (default en).
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#fafaf9" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0c0a09" media="(prefers-color-scheme: dark)" />
    <meta name="description" content="xBuilderPulse — a readable mobile-friendly reader for BuilderPulse Daily." />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="BuilderPulse" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <title>BuilderPulse Reader</title>
    <script is:inline>
      (function () {
        var lang = 'en';
        try {
          var stored = localStorage.getItem('bp-lang');
          if (stored === 'en' || stored === 'zh') {
            lang = stored;
          } else if (navigator.language && /^zh/i.test(navigator.language)) {
            lang = 'zh';
          }
        } catch (_) {}
        location.replace('/' + lang);
      })();
    </script>
    <meta http-equiv="refresh" content="0; url=/en" />
  </head>
  <body>
    <p>
      <a href="/en">English</a> / <a href="/zh">中文</a>
    </p>
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js', { scope: '/' }).catch(() => {});
        });
      }
    </script>
  </body>
</html>
