---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import { listReports, type Lang } from '../../lib/github';

export async function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}

const { lang } = Astro.params as { lang: Lang };
const metas = await listReports(lang);

// Group by year
const byYear = new Map<string, typeof metas>();
for (const m of metas) {
  if (!byYear.has(m.year)) byYear.set(m.year, []);
  byYear.get(m.year)!.push(m);
}
const years = [...byYear.keys()].sort((a, b) => b.localeCompare(a));

const title =
  lang === 'zh' ? '归档 · BuilderPulse' : 'Archive · BuilderPulse';
---

<BaseLayout title={title} lang={lang}>
  <Header lang={lang} currentPath={Astro.url.pathname} />

  <main class="mx-auto max-w-2xl px-4 py-6 pb-24">
    <h1 class="text-2xl font-bold mb-6">
      {lang === 'zh' ? '归档' : 'Archive'}
    </h1>

    {
      years.map((year) => (
        <section class="mb-8">
          <h2
            class="text-xs uppercase tracking-widest font-semibold mb-3"
            style="color: var(--color-muted);"
          >
            {year}
          </h2>
          <ul class="flex flex-col divide-y" style="border-color: var(--color-border);">
            {byYear.get(year)!.map((m) => (
              <li>
                <a
                  href={`/${lang}/${m.year}/${m.slug}`}
                  class="flex items-center justify-between py-3 gap-3 active:opacity-60"
                >
                  <span class="font-mono text-sm" style="color: var(--color-muted);">
                    {m.date}
                  </span>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" style="color: var(--color-muted);">
                    <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }

    {
      metas.length === 0 && (
        <p class="text-sm" style="color: var(--color-muted);">
          {lang === 'zh' ? '暂无内容。' : 'Nothing yet.'}
        </p>
      )
    }
  </main>
</BaseLayout>
